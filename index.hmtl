<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#111111">
  <meta name="description" content="Links oficiais do Gr&atilde;oCheff Caf&eacute; e Bistr&ocirc;">
  <title>Gr&atilde;oCheff | HazeLink</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@600;700&family=Playfair+Display:wght@600;700;800&family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --espresso: #111111;
      --coffee: #2a170d;
      --brown: #6b3e16;
      --wood: #8b5e34;
      --gold: #f2b200;
      --cream: #fff4df;
      --rose: #e91e63;
      --soft: rgba(230, 230, 230, .76);
      font-family: "Poppins", system-ui, sans-serif;
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html, body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: var(--espresso);
      color: var(--cream);
      font-family: "Poppins", system-ui, sans-serif;
      letter-spacing: 0;
      -webkit-tap-highlight-color: transparent;
      touch-action: none;
    }

    .video-layer {
      position: fixed;
      inset: 0;
      z-index: 1;
      overflow: hidden;
      background: var(--espresso);
    }

    .video-layer video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      filter: saturate(1.12) contrast(1.04) brightness(1.02);
    }

    .video-layer::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 2;
      pointer-events: none;
      background:
        radial-gradient(circle at 78% 18%, rgba(242, 178, 0, .2), transparent 16rem),
        linear-gradient(to bottom, rgba(17, 17, 17, .04), rgba(17, 17, 17, .28));
      mix-blend-mode: multiply;
    }

    .video-layer::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 3;
      height: 280px;
      pointer-events: none;
      background: linear-gradient(to top, rgba(0, 0, 0, .58), transparent);
    }

    .brand-lockup {
      position: fixed;
      left: 18px;
      top: calc(18px + env(safe-area-inset-top, 0px));
      z-index: 8;
      display: grid;
      gap: 6px;
      max-width: calc(100% - 96px);
      color: var(--cream);
      text-shadow: 0 2px 18px rgba(0, 0, 0, .58);
    }

    .brand-logo {
      width: min(214px, 58vw);
      height: auto;
      display: block;
      filter:
        brightness(1.28)
        saturate(1.18)
        contrast(1.12)
        drop-shadow(0 10px 18px rgba(0, 0, 0, .58))
        drop-shadow(0 0 14px rgba(242, 178, 0, .28));
    }

    .sound-btn {
      position: fixed;
      top: calc(20px + env(safe-area-inset-top, 0px));
      right: 16px;
      z-index: 12;
      width: 48px;
      height: 48px;
      border: 1px solid rgba(230, 230, 230, .18);
      border-radius: 50%;
      display: grid;
      place-items: center;
      color: var(--cream);
      background: rgba(17, 17, 17, .7);
      backdrop-filter: blur(12px);
      cursor: pointer;
      transition: transform .18s ease, background .18s ease, color .18s ease;
    }

    .sound-btn:active {
      transform: scale(.94);
    }

    .sound-btn.sound-on {
      color: var(--espresso);
      background: var(--gold);
    }

    .swipe-hint {
      position: fixed;
      left: 50%;
      bottom: calc(36px + env(safe-area-inset-bottom, 0px));
      z-index: 10;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 7px;
      color: var(--cream);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: .08em;
      text-transform: uppercase;
      text-align: center;
      pointer-events: none;
      text-shadow: 0 2px 12px rgba(0, 0, 0, .62);
      transition: opacity .35s ease, transform .35s ease;
    }

    .swipe-hint.hidden {
      opacity: 0;
      transform: translate(-50%, 12px);
    }

    .swipe-circle {
      width: 54px;
      height: 54px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      color: var(--espresso);
      background: var(--gold);
      box-shadow: 0 16px 34px rgba(0, 0, 0, .34);
      animation: floatArrow 1.55s ease-in-out infinite;
    }

    @keyframes floatArrow {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    .card-panel {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 20;
      max-height: 92vh;
      overflow-y: auto;
      color: var(--cream);
      border-radius: 28px 28px 0 0;
      border: 1px solid rgba(230, 230, 230, .12);
      border-bottom: 0;
      background:
        radial-gradient(circle at 86% 3%, rgba(242, 178, 0, .34), transparent 13rem),
        radial-gradient(circle at 4% 12%, rgba(233, 30, 99, .18), transparent 11rem),
        linear-gradient(165deg, rgba(89, 44, 14, .96) 0%, rgba(45, 23, 10, .98) 52%, rgba(22, 12, 7, .99) 100%);
      box-shadow: 0 -24px 74px rgba(0, 0, 0, .38);
      transform: translateY(100%);
      transition: transform .42s cubic-bezier(.4, 0, .2, 1);
      will-change: transform;
      -webkit-overflow-scrolling: touch;
      backdrop-filter: blur(18px);
      scrollbar-width: none;
    }

    .card-panel::-webkit-scrollbar {
      display: none;
    }

    .card-panel.open {
      transform: translateY(0);
    }

    .card-panel.no-anim {
      transition: none;
    }

    .card-handle {
      width: 42px;
      height: 5px;
      border-radius: 999px;
      margin: 13px auto 0;
      background: rgba(230, 230, 230, .2);
      cursor: pointer;
    }

    .card-body {
      width: min(440px, 100%);
      margin: 0 auto;
      padding: 14px 22px calc(26px + env(safe-area-inset-bottom, 0px));
      display: grid;
      justify-items: center;
      text-align: center;
    }

    .panel-hero {
      width: 100%;
      display: grid;
      justify-items: center;
      padding: 2px 0 14px;
      position: relative;
    }

    .panel-hero::before {
      content: "";
      position: absolute;
      top: 8px;
      width: min(330px, 82%);
      height: 128px;
      border-radius: 50%;
      background:
        radial-gradient(ellipse at center, rgba(242, 178, 0, .22), rgba(242, 178, 0, .08) 46%, transparent 72%);
      filter: blur(10px);
      pointer-events: none;
    }

    .panel-logo-wrap {
      position: relative;
      display: grid;
      place-items: center;
      width: 100%;
      min-height: 94px;
      margin: 0 0 8px;
      overflow: hidden;
    }

    .panel-logo {
      position: relative;
      width: min(286px, 88%);
      height: 94px;
      object-fit: cover;
      object-position: center;
      display: block;
      filter:
        brightness(1.55)
        saturate(1.34)
        contrast(1.18)
        drop-shadow(0 14px 24px rgba(0, 0, 0, .52))
        drop-shadow(0 0 24px rgba(242, 178, 0, .3));
    }

    .panel-title {
      position: relative;
      max-width: 350px;
      margin: 0;
      color: #fff8ea;
      font-family: "Playfair Display", Georgia, serif;
      font-size: clamp(25px, 6.8vw, 33px);
      line-height: 1.08;
      font-weight: 800;
      text-wrap: balance;
      text-shadow: 0 3px 16px rgba(0, 0, 0, .54);
    }

    .biz-tagline {
      position: relative;
      max-width: 334px;
      margin: 8px 0 0;
      color: rgba(255, 244, 223, .9);
      font-size: 13px;
      line-height: 1.5;
      font-weight: 700;
    }

    .biz-tagline strong {
      color: var(--gold);
      font-weight: 900;
    }

    .divider {
      width: 100%;
      height: 1px;
      margin-bottom: 16px;
      background: linear-gradient(90deg, transparent, rgba(255, 244, 223, .22), transparent);
    }

    .socials {
      display: flex;
      justify-content: center;
      gap: 12px;
      margin-bottom: 16px;
    }

    .social-btn {
      width: 46px;
      height: 46px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      color: #ffffff;
      border: 1px solid rgba(242, 178, 0, .34);
      background: #3a2112;
      text-decoration: none;
      box-shadow: 0 10px 20px rgba(0, 0, 0, .16);
      transition: transform .15s ease, background .15s ease, border-color .15s ease;
    }

    .social-btn.social-instagram {
      background:
        radial-gradient(circle at 30% 105%, #fdf497 0 16%, #fd5949 42%, #d6249f 68%, #285aeb 100%);
      border-color: rgba(255, 244, 223, .42);
    }

    .social-btn.social-whatsapp {
      background: #25d366;
      border-color: rgba(255, 255, 255, .42);
    }

    .social-btn svg {
      opacity: 1;
      filter: drop-shadow(0 1px 1px rgba(0, 0, 0, .24));
    }

    .social-btn:active {
      transform: scale(.92);
      background: rgba(242, 178, 0, .18);
    }

    .actions {
      width: 100%;
      display: grid;
      gap: 10px;
    }

    .action-btn {
      position: relative;
      min-height: 66px;
      display: flex;
      align-items: center;
      gap: 15px;
      padding: 13px 16px;
      border-radius: 18px;
      color: var(--cream);
      text-decoration: none;
      border: 1px solid rgba(230, 230, 230, .2);
      background: rgba(230, 230, 230, .07);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .16), 0 16px 30px rgba(0, 0, 0, .2);
      transition: transform .18s ease, filter .18s ease, background .18s ease, border-color .18s ease;
      min-width: 0;
      overflow: hidden;
    }

    .action-btn::after {
      content: "";
      position: absolute;
      inset: 1px;
      border-radius: 17px;
      background: linear-gradient(120deg, rgba(255, 255, 255, .18), transparent 38%, rgba(255, 255, 255, .08));
      pointer-events: none;
      opacity: .62;
    }

    .action-btn:active {
      transform: scale(.97);
      filter: brightness(.94);
    }

    @media (hover: hover) and (pointer: fine) {
      .action-btn:hover,
      .social-btn:hover {
        transform: translateY(-2px);
      }
    }

    .action-btn.menu {
      background:
        radial-gradient(circle at 92% 12%, rgba(255, 250, 208, .48), transparent 7rem),
        linear-gradient(135deg, #ffc533 0%, #f5b300 46%, #cf7a00 100%);
      color: #130d04;
      border-color: rgba(255, 238, 178, .72);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .32), 0 15px 34px rgba(242, 178, 0, .2);
    }

    .action-btn.whatsapp {
      background:
        radial-gradient(circle at 92% 12%, rgba(255, 226, 237, .3), transparent 7rem),
        linear-gradient(135deg, #ff4f91 0%, #e91e63 50%, #a70d40 100%);
      border-color: rgba(255, 184, 211, .66);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .22), 0 15px 34px rgba(233, 30, 99, .2);
    }

    .action-btn.instagram {
      background:
        radial-gradient(circle at 90% 12%, rgba(242, 178, 0, .2), transparent 7rem),
        linear-gradient(135deg, #a56632 0%, #653416 54%, #321707 100%);
      border-color: rgba(242, 178, 0, .62);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .18), 0 15px 34px rgba(107, 62, 22, .22);
    }

    .action-btn.location {
      background:
        radial-gradient(circle at 90% 12%, rgba(242, 178, 0, .16), transparent 7rem),
        linear-gradient(135deg, #432515 0%, #241208 54%, #0f0805 100%);
      border-color: rgba(242, 178, 0, .58);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .13), 0 15px 34px rgba(0, 0, 0, .22);
    }

    .action-icon {
      position: relative;
      z-index: 1;
      width: 42px;
      height: 42px;
      flex: 0 0 42px;
      border-radius: 14px;
      display: grid;
      place-items: center;
      color: inherit;
      background: rgba(255, 244, 223, .96);
      border: 1px solid rgba(255, 255, 255, .2);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .32), 0 8px 16px rgba(0, 0, 0, .18);
    }

    .action-icon svg {
      opacity: 1;
      filter: drop-shadow(0 1px 0 rgba(0, 0, 0, .1));
    }

    .action-copy {
      position: relative;
      z-index: 1;
      min-width: 0;
      display: grid;
      gap: 2px;
      text-align: left;
      overflow: hidden;
    }

    .action-copy strong {
      font-size: 17px;
      line-height: 1.08;
      font-weight: 900;
      color: inherit;
      text-shadow: 0 2px 6px rgba(0, 0, 0, .44);
    }

    .action-copy span {
      font-size: 12.6px;
      line-height: 1.32;
      font-weight: 800;
      color: rgba(255, 248, 234, .98);
      text-shadow: 0 2px 6px rgba(0, 0, 0, .46);
      overflow-wrap: anywhere;
    }

    .action-btn.menu .action-copy strong,
    .action-btn.menu .action-copy span {
      text-shadow: none;
    }

    .action-btn.menu .action-copy span {
      color: rgba(19, 13, 4, .96);
    }

    .action-btn.menu .action-icon {
      color: var(--gold);
      background: #1b1007;
      border-color: rgba(255, 244, 223, .18);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .12), 0 8px 14px rgba(130, 76, 0, .26);
    }

    .action-btn.whatsapp .action-icon {
      color: #ffffff;
      background: #25d366;
      border-color: rgba(255, 255, 255, .44);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .24), 0 8px 14px rgba(127, 0, 45, .22);
    }

    .action-btn.instagram .action-icon {
      color: #ffffff;
      background:
        radial-gradient(circle at 30% 105%, #fdf497 0 16%, #fd5949 42%, #d6249f 68%, #285aeb 100%);
      border-color: rgba(255, 244, 223, .34);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .24), 0 8px 14px rgba(45, 22, 5, .24);
    }

    .action-btn.location .action-icon {
      color: #160c05;
      background: #fff4df;
      border-color: rgba(255, 244, 223, .2);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .1), 0 8px 14px rgba(0, 0, 0, .26);
    }

    .action-btn.whatsapp .action-copy strong,
    .action-btn.whatsapp .action-copy span,
    .action-btn.instagram .action-copy strong,
    .action-btn.instagram .action-copy span,
    .action-btn.location .action-copy strong,
    .action-btn.location .action-copy span {
      color: #fff8ea;
    }

    .action-btn.location .action-copy span {
      color: rgba(255, 236, 198, .98);
    }

    .footer {
      display: none;
    }

    @media (min-width: 760px) {
      .brand-lockup {
        left: 30px;
        top: 28px;
      }

      .sound-btn {
        right: 28px;
        top: 28px;
      }

      .card-panel {
        left: 50%;
        right: auto;
        width: min(520px, calc(100% - 36px));
        transform: translate(-50%, 100%);
        border-radius: 28px 28px 0 0;
      }

      .card-panel.open {
        transform: translate(-50%, 0);
      }
    }
  </style>
</head>
<body>
  <div class="video-layer" aria-hidden="true">
    <video id="bgVideo" autoplay muted loop playsinline preload="auto">
      <source src="./assets/graocheffcafes.mp4" type="video/mp4">
    </video>
  </div>

  <header class="brand-lockup" aria-label="Gr&atilde;oCheff">
    <img class="brand-logo" src="assets/logo-graocheff.png" alt="Gr&atilde;oCheff Caf&eacute; e Bistr&ocirc;">
  </header>

  <button class="sound-btn" id="soundBtn" type="button" aria-label="Ativar som">
    <svg id="soundIcon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
      <path d="M16 9.5c.8.7 1.2 1.5 1.2 2.5s-.4 1.8-1.2 2.5"></path>
      <path d="M19 7c1.5 1.4 2.3 3.1 2.3 5s-.8 3.6-2.3 5"></path>
    </svg>
  </button>

  <div class="swipe-hint" id="swipeHint">
    <div class="swipe-circle" aria-hidden="true">
      <svg width="25" height="25" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.7" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </div>
    <span>Arraste para cima</span>
  </div>

  <section class="card-panel" id="cardPanel" aria-label="Links do Gr&atilde;oCheff">
    <div class="card-handle" id="cardHandle"></div>
    <div class="card-body">
      <div class="panel-hero">
        <div class="panel-logo-wrap">
          <img class="panel-logo" src="assets/logo-graocheff.png" alt="Gr&atilde;oCheff Caf&eacute; e Bistr&ocirc;">
        </div>
        <h1 class="panel-title">Feito com sabor, servido com amor</h1>
        <p class="biz-tagline">Caf&eacute;s especiais, pratos da casa e <strong>momentos que ficam</strong></p>
      </div>
      <div class="divider"></div>

      <div class="socials" aria-label="Redes sociais">
        <a class="social-btn social-instagram" href="https://www.instagram.com/graocheffcafes/" target="_blank" rel="noopener" aria-label="Instagram">
          <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle>
          </svg>
        </a>
        <a class="social-btn social-whatsapp" href="https://wa.me/558189564338?text=Oi%2C%20vi%20o%20HazeLink%20do%20GraoCheff%20e%20quero%20fazer%20um%20pedido" target="_blank" rel="noopener" aria-label="WhatsApp">
          <svg width="21" height="21" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97c-.27-.1-.47-.15-.67.15c-.2.3-.77.97-.94 1.16c-.17.2-.35.22-.64.08c-.3-.15-1.26-.46-2.39-1.48c-.88-.79-1.48-1.76-1.65-2.06c-.17-.3-.02-.46.13-.61c.13-.13.3-.35.45-.52c.15-.17.2-.3.3-.5c.1-.2.05-.37-.03-.52c-.07-.15-.67-1.61-.92-2.21c-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37c-.27.3-1.04 1.02-1.04 2.48c0 1.46 1.07 2.88 1.21 3.07c.15.2 2.1 3.2 5.08 4.49c.71.31 1.26.49 1.69.63c.71.23 1.36.2 1.87.12c.57-.09 1.76-.72 2.01-1.41c.25-.69.25-1.29.17-1.41c-.07-.12-.27-.2-.57-.35"></path>
          </svg>
        </a>
      </div>

      <div class="actions">
        <a class="action-btn menu" href="https://wa.me/558189564338?text=Oi%2C%20vi%20o%20HazeLink%20do%20GraoCheff%20e%20quero%20ver%20o%20cardapio" target="_blank" rel="noopener">
          <span class="action-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19h16"></path>
              <path d="M6 19V9a6 6 0 0 1 12 0v10"></path>
              <path d="M8 9h8"></path>
            </svg>
          </span>
          <span class="action-copy">
            <strong>Ver card&aacute;pio</strong>
            <span>Caf&eacute;s, doces e pratos especiais</span>
          </span>
        </a>

        <a class="action-btn whatsapp" href="https://wa.me/558189564338?text=Oi%2C%20vi%20o%20HazeLink%20do%20GraoCheff%20e%20quero%20fazer%20um%20pedido" target="_blank" rel="noopener">
          <span class="action-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97c-.27-.1-.47-.15-.67.15c-.2.3-.77.97-.94 1.16c-.17.2-.35.22-.64.08c-.3-.15-1.26-.46-2.39-1.48c-.88-.79-1.48-1.76-1.65-2.06c-.17-.3-.02-.46.13-.61c.13-.13.3-.35.45-.52c.15-.17.2-.3.3-.5c.1-.2.05-.37-.03-.52c-.07-.15-.67-1.61-.92-2.21c-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37c-.27.3-1.04 1.02-1.04 2.48c0 1.46 1.07 2.88 1.21 3.07c.15.2 2.1 3.2 5.08 4.49c.71.31 1.26.49 1.69.63c.71.23 1.36.2 1.87.12c.57-.09 1.76-.72 2.01-1.41c.25-.69.25-1.29.17-1.41c-.07-.12-.27-.2-.57-.35"></path>
            </svg>
          </span>
          <span class="action-copy">
            <strong>Pedir no WhatsApp</strong>
            <span>Pedido r&aacute;pido e atendimento direto</span>
          </span>
        </a>

        <a class="action-btn instagram" href="https://www.instagram.com/graocheffcafes/" target="_blank" rel="noopener">
          <span class="action-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <circle cx="12" cy="12" r="4"></circle>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"></circle>
            </svg>
          </span>
          <span class="action-copy">
            <strong>Instagram</strong>
            <span>Novidades, bastidores e sabores</span>
          </span>
        </a>

        <a class="action-btn location" href="https://maps.app.goo.gl/PM6DbhwcfktCtjk78" target="_blank" rel="noopener">
          <span class="action-icon" aria-hidden="true">
            <svg width="23" height="23" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2.2A7.7 7.7 0 0 0 4.3 10c0 4.9 5.1 9.7 7.7 11.8V13.2A3.2 3.2 0 0 1 12 6.8V2.2Z" fill="#EA4335"></path>
              <path d="M12 2.2V6.8a3.2 3.2 0 0 1 3.2 3.2c0 1.2-.7 2.3-1.7 2.8l4.5 4.5c1-1.7 1.7-3.5 1.7-5.3A7.7 7.7 0 0 0 12 2.2Z" fill="#FBBC04"></path>
              <path d="M12 21.8c1.4-1.1 3.9-3.4 6-6.5l-4.5-4.5a3.1 3.1 0 0 1-1.5.4v10.6Z" fill="#34A853"></path>
              <circle cx="12" cy="10" r="2.8" fill="#4285F4"></circle>
            </svg>
          </span>
          <span class="action-copy">
            <strong>Como chegar</strong>
            <span>Abra o endere&ccedil;o no Google Maps</span>
          </span>
        </a>
      </div>

      <p class="footer">Feito com HazeLink para Gr&atilde;oCheff</p>
    </div>
  </section>

  <script>
    const panel = document.getElementById("cardPanel");
    const hint = document.getElementById("swipeHint");
    const handle = document.getElementById("cardHandle");
    const video = document.getElementById("bgVideo");
    const soundBtn = document.getElementById("soundBtn");
    const soundIcon = document.getElementById("soundIcon");

    let startY = 0;
    let lastY = 0;
    let dragging = false;
    let isOpen = false;
    let soundEnabled = false;
    const rawVideoSrc = "./assets/graocheffcafes.mp4";

    const soundOffSvg = '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><line x1="22" y1="9" x2="16" y2="15"></line><line x1="16" y1="9" x2="22" y2="15"></line>';
    const soundOnSvg = '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M16 9.5c.8.7 1.2 1.5 1.2 2.5s-.4 1.8-1.2 2.5"></path><path d="M19 7c1.5 1.4 2.3 3.1 2.3 5s-.8 3.6-2.3 5"></path>';

    function setSoundState(enabled) {
      soundEnabled = enabled;
      video.muted = !enabled;
      soundBtn.classList.toggle("sound-on", enabled);
      soundBtn.setAttribute("aria-label", enabled ? "Desativar som" : "Ativar som");
      soundIcon.innerHTML = enabled ? soundOnSvg : soundOffSvg;
    }

    async function playVideo() {
      try {
        await video.play();
        setSoundState(!video.muted);
      } catch (error) {
        video.muted = true;
        setSoundState(false);
        try { await video.play(); } catch (silentError) {}
      }
    }

    function useRawVideoFallback() {
      if (video.dataset.fallback === "raw") return;
      video.dataset.fallback = "raw";
      video.src = rawVideoSrc;
      video.load();
      playVideo();
    }

    async function enableSound() {
      setSoundState(true);
      await playVideo();
    }

    function openPanel() {
      isOpen = true;
      panel.classList.remove("no-anim");
      panel.classList.add("open");
      panel.style.transform = "";
      hint.classList.add("hidden");
    }

    function closePanel() {
      isOpen = false;
      panel.classList.remove("no-anim");
      panel.classList.remove("open");
      panel.style.transform = "";
      hint.classList.remove("hidden");
    }

    function snapBack() {
      panel.classList.remove("no-anim");
      panel.style.transform = "";
      isOpen ? panel.classList.add("open") : panel.classList.remove("open");
    }

    function onStart(y, target) {
      if (target && target.closest("a, button")) return;
      startY = y;
      lastY = y;
      dragging = true;
      if (!soundEnabled) enableSound();
    }

    function onMove(y) {
      if (!dragging) return;
      lastY = y;
      const diff = startY - lastY;
      panel.classList.add("no-anim");

      if (!isOpen && diff > 5) {
        const progress = Math.min(diff / 230, 1);
        const base = (1 - progress) * 100;
        panel.style.transform = window.innerWidth >= 760 ? `translate(-50%, ${base}%)` : `translateY(${base}%)`;
      }

      if (isOpen && diff < -5) {
        const down = Math.max(0, -diff);
        panel.style.transform = window.innerWidth >= 760 ? `translate(-50%, ${down}px)` : `translateY(${down}px)`;
      }
    }

    function onEnd() {
      if (!dragging) return;
      dragging = false;
      const diff = startY - lastY;

      if (!isOpen && diff > 70) openPanel();
      else if (isOpen && diff < -70) closePanel();
      else snapBack();
    }

    setSoundState(false);
    video.muted = true;
    playVideo();

    video.addEventListener("error", useRawVideoFallback);
    setTimeout(() => {
      if (!video.readyState || video.videoWidth === 0) useRawVideoFallback();
    }, 2600);

    soundBtn.addEventListener("click", async (event) => {
      event.preventDefault();
      event.stopPropagation();
      setSoundState(!soundEnabled);
      await playVideo();
    });

    soundBtn.addEventListener("touchstart", (event) => event.stopPropagation(), { passive: true });
    soundBtn.addEventListener("mousedown", (event) => event.stopPropagation());
    handle.addEventListener("click", () => isOpen ? closePanel() : openPanel());

    document.addEventListener("touchstart", (event) => onStart(event.touches[0].clientY, event.target), { passive: true });
    document.addEventListener("touchmove", (event) => { event.preventDefault(); onMove(event.touches[0].clientY); }, { passive: false });
    document.addEventListener("touchend", onEnd);

    document.addEventListener("mousedown", (event) => onStart(event.clientY, event.target));
    document.addEventListener("mousemove", (event) => { if (dragging) onMove(event.clientY); });
    document.addEventListener("mouseup", onEnd);
    document.addEventListener("mouseleave", onEnd);
  </script>
</body>
</html>
